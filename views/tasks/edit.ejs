<%- include('../partials/header') %>

<h2>Edit Task</h2>

<form method="POST" action="/tasks/edit/<%= task.task_id %>">
  <input type="hidden" name="_method" value="PUT">

<% if (user.role === 'admin') { %>

  <!-- ===== ADMIN ===== -->
  Owner:
  <select id="ownerSelect">
    <option value="">-- Select Owner --</option>
    <% users.forEach(u => { %>
      <option value="<%= u.user_id %>"
        <%= task.Project && task.Project.user_id == u.user_id ? 'selected' : '' %>>
        <%= u.name %>
      </option>
      
    <% }) %>
  </select>
  <br>

<% } else { %>

  <!-- ===== USER ===== -->
  <p><strong>Owner:</strong> <%= user.name %></p>
  <input type="hidden" id="ownerSelect" value="<%= user.user_id %>">

<% } %>


Project:
<select name="project_id" id="projectSelect" required>
  <option value="">-- Select Project --</option>
  <% if (user.role === 'admin') { %>
    <!-- Admin projects will be loaded dynamically from users array -->
  <% } else { %>
    <!-- Non-admin users see their own projects -->
    <% if (projects && projects.length > 0) { %>
      <% projects.forEach(p => { %>
        <option value="<%= p.project_id %>"
          <%= task.project_id == p.project_id ? 'selected' : '' %>>
          <%= p.project_name %>
        </option>
      <% }) %>
    <% } else { %>
      <option value="" disabled>No projects available</option>
    <% } %>
  <% } %>
</select>
<br>

Title:
<input name="title" value="<%= task.title %>" required><br>

Description:
<textarea name="description"><%= task.description %></textarea><br>

Priority:
<select name="priority">
  <option value="low" <%= task.priority === 'low' ? 'selected' : '' %>>Low</option>
  <option value="medium" <%= task.priority === 'medium' ? 'selected' : '' %>>Medium</option>
  <option value="high" <%= task.priority === 'high' ? 'selected' : '' %>>High</option>
</select>
<br>

Status:
<select name="status">
  <option value="Planning" <%= task.status === 'Planning' ? 'selected' : '' %>>Planning</option>
  <option value="In progress" <%= task.status === 'In progress' ? 'selected' : '' %>>In Progress</option>
  <option value="Completed" <%= task.status === 'Completed' ? 'selected' : '' %>>Completed</option>
</select>
<br>

Due Date:
<input type="date" name="due_date"
value="<%= task.due_date ? new Date(task.due_date).toISOString().split('T')[0] : '' %>">
<br>

<button type="submit"class="btn-update" >Update</button>
<button type="button" onclick="history.back()">Cancel</button>

</form>

<script>
const users = <%- JSON.stringify(users) %>;
const projects = <%- JSON.stringify(projects || []) %>;
const selectedProjectId = <%= task.project_id %>;

const ownerSelect = document.getElementById('ownerSelect');
const projectSelect = document.getElementById('projectSelect');

function loadProjects(userId) {
  projectSelect.innerHTML = '<option value="">-- Select Project --</option>';

  const user = users.find(u => u.user_id == userId);
  if (!user) return;

  // association data may come back under "Projects" (capitalized) depending on how
  // Sequelize was called, so check both variants
  const userProjects = user.projects || user.Projects || [];
  if (userProjects.length === 0) return;

  userProjects.forEach(p => {
    const option = document.createElement('option');
    option.value = p.project_id;
    option.textContent = p.project_name;

    if (p.project_id == selectedProjectId) {
      option.selected = true;
    }

    projectSelect.appendChild(option);
  });
}

// Only run for admin users (who have a select dropdown for owner)
if (ownerSelect && ownerSelect.tagName === 'SELECT') {
  ownerSelect.addEventListener('change', function () {
    loadProjects(this.value);
  });

  // Load initial projects if admin has a selected owner
  if (ownerSelect.value) {
    loadProjects(ownerSelect.value);
  }
}
</script>

<%- include('../partials/footer') %>