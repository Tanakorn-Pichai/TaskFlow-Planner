<%- include('../partials/header') %>

<h2>Tasks</h2>
<a href="/tasks/create">+ Create</a>

<!-- Search -->
<input type="text" class="table-search" placeholder="Search...">

<table class="styled-table data-table">
<thead>
<tr>
<th data-column="0">Title</th>
<th data-column="1">Project</th>
<th data-column="2">Owner</th>
<th data-column="3">Status</th>
<th data-column="4">Priority</th>
<th>Action</th>
</tr>
</thead>

<tbody>
<% tasks.forEach((t, index) => { %>
<tr>

<td>
  <% if (user.role === 'admin') { %>
    <%= t.title %>
  <% } else { %>
    <%= index + 1 %>
  <% } %>
</td>

<td><%= t.Project ? t.Project.project_name : '' %></td>

<td>
  <%= t.Project && t.Project.User 
      ? t.Project.User.name 
      : '' %>
</td>

<td><%= t.status %></td>
<td><%= t.priority %></td>

<td>
  <a href="/tasks/show/<%= t.task_id %>">Show</a>

  <% if (
      user.role === 'admin' ||
      (t.Project && t.Project.user_id === user.user_id)
  ) { %>

    <a href="/tasks/edit/<%= t.task_id %>">Edit</a>
    <a href="/tasks/delete/<%= t.task_id %>" 
       onclick="return confirm('Delete this task?')">
       Delete
    </a>

  <% } %>
</td>

</tr>
<% }) %>
</tbody>
</table>

<script src="/js/table.js"></script>

<%- include('../partials/footer') %>