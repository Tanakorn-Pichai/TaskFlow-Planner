<%- include('../partials/header') %>

<h2>Users</h2>

<a href="/users/create">+ Create</a>

<input type="text" class="table-search" placeholder="Search...">

<table class="styled-table data-table">
<thead>
<tr>
<th data-column="0">Name</th>
<th data-column="1">Email</th>
<th data-column="2">Role</th>
<th data-column="3">Created At</th>
<th>Action</th>
</tr>
</thead>

<tbody>
<% users.forEach((u) => { %>
<tr>
<td><%= u.name %></td>
<td><%= u.email %></td>
<td><%= u.role %></td>
<td><%= new Date(u.created_at).toLocaleDateString() %></td>
<td>
  <a href="/users/<%= u.user_id %>">Show</a>
  <a href="/users/<%= u.user_id %>/edit">Edit</a>
  <form method="POST" action="/users/<%= u.user_id %>?_method=DELETE" style="display: inline;" onsubmit="return confirm('Delete this user?')">
    <button type="submit" style="background: none; border: none; color: red; cursor: pointer;">Delete</button>
  </form>
</td>
</tr>
<% }) %>
</tbody>
</table>

<script src="/js/table.js"></script>

<%- include('../partials/footer') %>