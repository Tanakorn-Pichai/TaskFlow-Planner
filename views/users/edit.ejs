<%- include('../partials/header') %>

<h2>Edit User</h2>

<form method="POST" action="/users/<%= viewUser.user_id %>?_method=PUT">
  <div class="form-group">
    <label>Name:</label>
    <input type="text" name="name" value="<%= viewUser.name %>" required>
  </div>

  <div class="form-group">
    <label>Email:</label>
    <input type="email" name="email" value="<%= viewUser.email %>" required>
  </div>

  <div class="form-group">
    <label>Role:</label>
    <select name="role">
      <option value="user" <%= viewUser.role === 'user' ? 'selected' : '' %>>User</option>
      <option value="admin" <%= viewUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
    </select>
  </div>

  <button type="submit" class="btn-update">Update</button>
  <button type="button" onclick="history.back()">Cancel</button>
</form>

<%- include('../partials/footer') %>