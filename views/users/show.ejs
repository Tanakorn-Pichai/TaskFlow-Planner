<%- include('../partials/header') %>

<h2>User Detail</h2>

<div class="stat-card users" style="max-width:700px;">

  <div style="margin-bottom:20px;">
   
  <h3><%= viewUser.name %></h3>
  </div>

  <table>
    <tbody>
    
<tr>
        <th>Email</th>
        <td>
          <%= viewUser.email %>
        </td>
      </tr>
      <tr>
        <th style="width:180px;">Role</th>
        <td>
          <% if (viewUser.role === 'admin') { %>
            <span class="role-badge admin">Admin</span>
          <% } else { %>
            <span class="role-badge user">User</span>
          <% } %>
        </td>
      </tr>

      <tr>
        <th>Created At</th>
        <td>
          <%= new Date(viewUser.created_at).toLocaleString() %>
        </td>
      </tr>

  

    </tbody>
  </table>

  <!-- Action Buttons -->
  <div style="margin-top:25px; display:flex; gap:10px; flex-wrap:wrap;">

<!-- Edit -->
<a href="/users/edit/<%= viewUser.user_id %>">
  <button type="button" class="btn-warning">✏️ Edit</button>
</a>

<a href="/users/delete/<%= viewUser.user_id %>">
  <button type="button" class="btn-danger">🗑 Delete</button>
</a>


    <button type="button" onclick="history.back()" class="btn-secondary">⬅ Back</button>


  </div>

</div>

<%- include('../partials/footer') %>