<%- include('../partials/header') %>

<h2>Task Logs</h2>

<input type="text" class="table-search" placeholder="Search...">

<table class="styled-table data-table">
<thead>
<tr>
<th data-column="0">Task</th>
<th data-column="1">Project</th>
<th data-column="2">Owner</th>
<th data-column="3">Action</th>
<th data-column="4">Time Spent</th>
<th data-column="5">Date</th>
<th>Action</th>
</tr>
</thead>

<tbody>
<% taskLogs.forEach((l, index) => { %>
  <% if (l.Task && l.Task.Project && l.Task.Project.User) { %>
  <tr>

<td>
  <% if (user.role === 'admin') { %>
    <%= l.Task?.title || '' %>
  <% } else { %>
    Task #<%= index + 1 %>
  <% } %>
</td>

<td>
  <%= l.Task?.Project?.project_name || '' %>
</td>

<td>
  <%= l.Task?.Project?.User?.name || '' %>
</td>

<td>
  <%= l.action %>
</td>

<td data-value="<%= l.time_spent %>">
  <% 
    const hours = Math.floor((l.time_spent || 0) / 60);
    const minutes = (l.time_spent || 0) % 60;
  %>
  <%= hours > 0 ? hours + ' hr ' : '' %><%= minutes %> min
</td>

<td data-value="<%= l.created_at %>">
  <%= l.created_at ? new Date(l.created_at).toLocaleDateString('en-GB') : '' %>
</td>

<td>
  <a href="/task-logs/show/<%= l.log_id %>">Show</a>
</td>

</tr>
  <% } %>
<% }) %>
</tbody>
</table>

<script src="/js/table.js"></script>

<%- include('../partials/footer') %>