<!DOCTYPE html>
<html>
<head>
  <title>TaskFlow Planner</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav>
  <a href="/">Home</a> |
    <% if (user && user.role === 'admin') { %>
    <a href="/users">Manage Users</a>
  <% } %>
  <a href="/projects">Manage Projects</a>
  <a href="/tasks">Manage Tasks</a>
  <a href="/task-logs">Tasks Log</a>
  <a href="/reports/longestTasks">Report 1</a>
  <a href="/reports/user-performance">Report 2</a>
<% if (user) { %>
  <span class="user-info">
    👤 <%= user.name %>
    <span class="role-badge <%= user.role %>">
      <%= user.role %>
    </span>
  </span>
  <a href="/logout" class="logout-btn">Logout</a>
<% } %>
</nav>
<hr>